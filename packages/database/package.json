{
  "name": "@travel-pins/database",
  "version": "0.0.0",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc && ln -snf ../generated dist/generated",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:force": "echo '⚠️  DEV ONLY: 컬럼 삭제·타입 변경 등 비가역적 데이터 손실을 자동 승인합니다.' && printf 'y를 입력하면 실행합니다: ' && read -r ans && if [ \"$ans\" = 'y' ]; then prisma db push --accept-data-loss; else echo '취소되었습니다.'; fi",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@travel-pins/eslint-config": "workspace:*",
    "@travel-pins/typescript-config": "workspace:*",
    "@types/pg": "^8.18.0",
    "dotenv": "^16.4.5",
    "prisma": "^7.0.0",
    "typescript": "^5.1.3"
  }
}

generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PlaceType {
  CAFE
  FOOD
  STORE
  PLACE
  PARKING

  @@map("place_type")
}

enum SocialType {
  KAKAO
  GOOGLE
  FACEBOOK
  INSTAGRAM
  APPLE
  NAVER

  @@map("social_type")
}

model Users {
  id         String     @id @default(uuid()) @db.Uuid
  nickname   String     @unique @db.VarChar(20)
  profile    String?    @db.VarChar(100)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  socialType SocialType @map("social_type")
  socialId   String     @unique @map("social_id")

  myPlaces MyPlaces[]
  groups   GroupMembers[]
  reviews  Reviews[]

  @@index([createdAt])
  @@map("users")
}

model Places {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(50)
  address       String    @db.VarChar(200)
  detailAddress String?   @map("detail_address") @db.VarChar(100)
  postcode      String    @db.VarChar(6)
  thumbnail     String?   @db.VarChar(100)
  type          PlaceType
  lat           Float
  lng           Float
  categoryId    Int?      @map("category_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  category Category?  @relation(fields: [categoryId], references: [id])
  myPlaces MyPlaces[]
  reviews  Reviews[]

  @@index([name])
  @@index([address])
  @@index([type])
  @@index([lat])
  @@index([lng])
  @@map("places")
}

model MyPlaces {
  placeId   String   @map("place_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  place     Places   @relation(fields: [placeId], references: [id])
  user      Users    @relation(fields: [userId], references: [id])

  @@id([placeId, userId])
  @@map("my_places")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique() @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  places Places[]

  @@map("category")
}

model Reviews {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(100)
  content   String   @db.Text
  placeId   String   @map("place_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  place  Places         @relation(fields: [placeId], references: [id])
  user   Users          @relation(fields: [userId], references: [id])
  images ReviewImages[]

  @@map("reviews")
}

model ReviewImages {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  pathname  String   @db.VarChar(100)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  review Reviews @relation(fields: [reviewId], references: [id])

  @@map("review_images")
}

model Groups {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  members GroupMembers[]
  travels Travels[]

  @@map("groups")
}

model GroupMembers {
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  group Groups @relation(fields: [groupId], references: [id])
  user  Users  @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

model Travels {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  region    String   @db.VarChar(100)
  deleted   Boolean  @default(false)
  groupId   String?  @map("group_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  group Groups? @relation(fields: [groupId], references: [id])

  @@map("travels")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../src/database/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlaceType {
  CAFE
  FOOD
  STORE

  @@map("place_type")
}

model Users {
  id        String   @db.Uuid @id @default(uuid())
  nickname  String   @db.VarChar(20) @unique
  profile   String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @default(now()) @map("updated_at")

  myPlaces MyPlaces[]

  @@index([createdAt])
  @@map("users")
}

model Places {
  id        String    @db.Uuid @id @default(uuid())
  name      String    @db.VarChar(20)
  address   String    @db.VarChar(200)
  thumbnail String    @db.VarChar(100)
  type      PlaceType
  lat       Float
  lng       Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @default(now()) @map("updated_at")

  myPlaces MyPlaces[]

  @@index([name])
  @@index([address])
  @@index([type])
  @@index([lat, lng])
  @@map("places")
}

model MyPlaces {
  placeId   String   @db.Uuid @map("place_id")
  userId    String   @db.Uuid @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  place     Places   @relation(fields: [placeId], references: [id])
  user      Users    @relation(fields: [userId], references: [id])

  @@id([placeId, userId])
  @@map("my_places")
}

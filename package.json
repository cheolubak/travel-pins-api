{
  "name": "travel-pins",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @travel-pins/database db:generate",
    "db:push": "pnpm --filter @travel-pins/database db:push",
    "db:push:force": "pnpm --filter @travel-pins/database db:push:force"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.4.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "@nestjs/core"
    ]
  }
}
